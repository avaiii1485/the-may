# Copy to .env.local and fill in. Without these the app falls back to
# localStorage-backed data and runs fully offline (no sign-in, no sync).
#
# Setup with Supabase:
#   1. Create a project at supabase.com.
#   2. SQL editor: run supabase/migrations/0001_init.sql, then 0002_questions_catalog.sql.
#   3. Authentication > Providers: enable "Anonymous sign-ins".
#   4. Paste the values below (Project Settings > API), then restart `npm run web`.
#   5. For Vercel, add the same two vars in Project Settings > Environment Variables.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
